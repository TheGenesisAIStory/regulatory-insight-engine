# Frontend
VITE_GENISIA_API_URL=http://127.0.0.1:8000

# Backend RAG paths
RAG_BASE_DIR=./  # optional: repository root
DOCS_PATH=./docs
CACHE_PATH=./backend/cache/embeddings_cache.pkl

# Ollama
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=qwen2.5:3b
EMBED_MODEL=embeddinggemma

# Retrieval / abstention
TOP_K=6
# Backend default is 0.12; current beta validation recommends 0.30 for stricter abstention.
SCORE_THRESHOLD=0.12
ENABLE_DOMAIN_GATE=false
DOMAIN_GATE_MODE=hybrid
# DOMAIN_GATE_TERMS_PATH=/absolute/path/to/domain_gate_terms.json

# Chunking / cache metadata
CHUNK_SIZE=420
CHUNK_OVERLAP=80

# Runtime
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=120
CHAT_TIMEOUT_SECONDS=240
CHAT_NUM_PREDICT=64
CHAT_NUM_CTX=2048
AUDIT_LOG_PATH=./docs/log/queries.jsonl
